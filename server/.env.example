# Cloud frontend URL
CLOUD_URL="your-cloud-url-here"

# Server credentials (from cloud frontend registration)
SERVER_ID="your-server-id-here"
API_KEY="your-api-key-here"

# Docker file storage root
ROOT_DIR=./data

# Server port
PORT=4000

# Docker Volume host directory for files (absolute path)
HOST_FILES_DIR="your-host-files-dir-here"
